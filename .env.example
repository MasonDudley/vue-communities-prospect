# Required for server-side contact submission inserts
SUPABASE_SERVICE_ROLE_KEY=

# Optional override; defaults to the production project URL in api/contact.js
SUPABASE_URL=https://povizsshrvyqcaszwzmr.supabase.co

# Optional Resend email notifications
RESEND_API_KEY=
CONTACT_NOTIFY_FROM=VUE Communities <onboarding@resend.dev>

# Fallback/default recipients (comma-separated supported)
CONTACT_NOTIFY_TO=

# Optional community-specific routing to preserve separation
CONTACT_NOTIFY_TO_OASIS=
CONTACT_NOTIFY_TO_CORNERSTONE=
CONTACT_NOTIFY_TO_STILL_DECIDING=

# Optional blind-copy recipients for internal visibility
CONTACT_NOTIFY_BCC=

# Optional origin restriction for the API route (comma-separated)
# Example: https://vuecommunities.com,https://www.vuecommunities.com,https://vue-communities.vercel.app
CONTACT_ALLOWED_ORIGINS=

# Optional per-instance in-memory rate limiting for /api/contact
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=600000
